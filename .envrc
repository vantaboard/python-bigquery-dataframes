# python-bigquery-dataframes submodule — see ../README.md (third_party overview).
# When you `cd` here, load the repo-root `.envrc` so BIGQUERY_EMULATOR_HOST,
# BIGQUERY_STORAGE_GRPC_ENDPOINT, GOOGLE_CLOUD_PROJECT / GCLOUD_PROJECT,
# STORAGE_EMULATOR_HOST, and PYTHON/DATAFRAME sample Python pins stay in sync
# with go-googlesql (`direnv allow` once in this directory after clone).
source_up

# samples/snippets/noxfile.py: editable install of bigframes from this checkout
# instead of the PyPI pin in requirements.txt.
export INSTALL_LIBRARY_FROM_SOURCE=true
